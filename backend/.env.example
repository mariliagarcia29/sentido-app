# App
NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentido
DB_USER=sentido
DB_PASSWORD=sentido_dev
DB_ENCRYPTION_KEY=dev_encryption_key_change_in_production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change_me_in_production_use_256bit_random_secret
JWT_EXPIRES_IN=7d

# AWS S3 (PDF storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=sentido-exports

# Frontend origin (CORS)
FRONTEND_ORIGIN=http://localhost:8081

# Firebase (Push Notifications)
FIREBASE_SERVICE_ACCOUNT_JSON=

# VAPID (Web Push)
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:contato@sentido.app

# Daily.co (Videochamada)
DAILY_API_KEY=
DAILY_DOMAIN=sentido

# Fitbit OAuth (Wearables)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://localhost:3001/api/v1/wearables/fitbit/callback

# Garmin OAuth
GARMIN_AUTH_URL=https://connect.garmin.com/oauthConfirm
GARMIN_CONSUMER_KEY=
GARMIN_VERIFICATION_TOKEN=
