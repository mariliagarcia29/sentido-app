# ============================================================
# Sentido App — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real no repositório
# ============================================================

# ── Ambiente ─────────────────────────────────────────────────
NODE_ENV=development          # development | staging | production
PORT=3001
TZ=America/Sao_Paulo

# ── Banco de Dados (PostgreSQL) ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentido
DB_USER=sentido
DB_PASSWORD=CHANGE_ME_strong_password
# Chave AES-256 para pgcrypto (emergency_contact e campos sensíveis)
# Gerar com: openssl rand -base64 32
DB_ENCRYPTION_KEY=CHANGE_ME_32_char_base64_key

# ── Cache / Filas (Redis) ─────────────────────────────────────
# Desenvolvimento: use Upstash (gratuito) ou Redis local via Docker
# Produção: ElastiCache (configurado pelo Terraform)
#
# Opção 1 — Redis local (docker-compose up redis):
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
#
# Opção 2 — Upstash (dev remoto, sem Docker):
# Crie uma instância gratuita em https://upstash.com → Redis
# e substitua as variáveis abaixo:
# REDIS_HOST=your-instance.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=CHANGE_ME_upstash_token
# REDIS_TLS=true

# ── JWT ───────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_very_long_random_secret
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# Separe múltiplas origens por vírgula
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:8081

# ── AWS ───────────────────────────────────────────────────────
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=sentido-exports-prod
AWS_CLOUDFRONT_DOMAIN=dXXXXXXXXXXXX.cloudfront.net

# ── Firebase (Push Notifications) ────────────────────────────
FIREBASE_PROJECT_ID=sentido-app
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@sentido-app.iam.gserviceaccount.com

# ── Web Push (VAPID) ─────────────────────────────────────────
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME_public_key
VAPID_PRIVATE_KEY=CHANGE_ME_private_key
VAPID_EMAIL=mailto:tech@sentido.app

# ── Telemedicina (Daily.co) ───────────────────────────────────
DAILY_API_KEY=CHANGE_ME
DAILY_DOMAIN=sentido              # seu subdomínio no daily.co

# ── Wearables — Fitbit ────────────────────────────────────────
FITBIT_CLIENT_ID=CHANGE_ME
FITBIT_CLIENT_SECRET=CHANGE_ME
FITBIT_REDIRECT_URI=https://api.sentido.app/api/v1/wearables/fitbit/callback

# ── Wearables — Garmin ────────────────────────────────────────
# Token compartilhado enviado no header X-Garmin-Verification-Token
# Gerar com: openssl rand -hex 32
GARMIN_VERIFICATION_TOKEN=CHANGE_ME_hex_token
GARMIN_AUTH_URL=https://connect.garmin.com/oauthConfirm

# ── Infraestrutura (preenchido automaticamente pelo ECS/CI) ───
ECR_REGISTRY=123456789.dkr.ecr.sa-east-1.amazonaws.com
IMAGE_TAG=latest
